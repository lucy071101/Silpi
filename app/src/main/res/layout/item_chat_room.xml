<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="96dp"
    android:background="#FFFFFF"
    android:clickable="true"
    android:clipToPadding="false"
    android:descendantFocusability="blocksDescendants"
    android:focusable="false"
    android:paddingStart="36dp"
    android:paddingTop="8dp"
    android:paddingEnd="36dp"
    android:paddingBottom="8dp">

    <FrameLayout
        android:id="@+id/layoutGroupProfileCluster"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_centerVertical="true"
        android:background="@drawable/bg_chat_list_avatar"
        android:padding="6dp"
        android:visibility="gone">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imageGroupProfile1"
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:layout_gravity="top|start"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlaySilpiCircleImage" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imageGroupProfile2"
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:layout_gravity="top|end"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlaySilpiCircleImage" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imageGroupProfile3"
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:layout_gravity="bottom|start"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlaySilpiCircleImage" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imageGroupProfile4"
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:layout_gravity="bottom|end"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlaySilpiCircleImage" />
    </FrameLayout>

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/imageViewProfile"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_centerVertical="true"
        android:background="@drawable/bg_default_profile"
        android:padding="0dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_default_profile_person"
        app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlaySilpiCircleImage" />

    <TextView
        android:id="@+id/textViewRoomName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="18dp"
        android:layout_marginTop="2dp"
        android:layout_toStartOf="@id/textViewTime"
        android:layout_toEndOf="@id/imageViewProfile"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="채팅방"
        android:textColor="#162033"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/textViewLastMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/textViewRoomName"
        android:layout_marginStart="18dp"
        android:layout_marginTop="5dp"
        android:layout_toStartOf="@id/textViewTime"
        android:layout_toEndOf="@id/imageViewProfile"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="대화를 시작해보세요"
        android:textColor="#5D6878"
        android:textSize="18sp" />

    <TextView
        android:id="@+id/textViewTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="18dp"
        android:text="오후 3:24"
        android:textColor="#5D6878"
        android:textSize="17sp" />

    <FrameLayout
        android:id="@+id/layoutUnreadBadge"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:layout_alignParentEnd="true"
        android:layout_below="@id/textViewTime"
        android:layout_marginTop="8dp"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:padding="0dp">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_gravity="center"
            android:contentDescription="@null"
            android:src="@drawable/bg_unread_count" />

        <TextView
            android:id="@+id/textViewUnreadCount"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:includeFontPadding="false"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp"
            android:singleLine="true"
            android:text="2"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold" />
    </FrameLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="-36dp"
        android:layout_marginEnd="-36dp"
        android:background="#E5E7EB" />

</RelativeLayout>
