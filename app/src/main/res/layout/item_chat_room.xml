<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="100dp"
    android:background="#FFFFFF"
    android:clickable="true"
    android:descendantFocusability="blocksDescendants"
    android:focusable="false"
    android:paddingStart="16dp"
    android:paddingTop="14dp"
    android:paddingEnd="16dp"
    android:paddingBottom="14dp">

    <FrameLayout
        android:id="@+id/layoutGroupProfileCluster"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_centerVertical="true"
        android:visibility="gone">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imageGroupProfile1"
            android:layout_width="27dp"
            android:layout_height="27dp"
            android:layout_gravity="top|start"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlaySilpiCircleImage" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imageGroupProfile2"
            android:layout_width="27dp"
            android:layout_height="27dp"
            android:layout_gravity="top|end"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlaySilpiCircleImage" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imageGroupProfile3"
            android:layout_width="27dp"
            android:layout_height="27dp"
            android:layout_gravity="bottom|start"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlaySilpiCircleImage" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imageGroupProfile4"
            android:layout_width="27dp"
            android:layout_height="27dp"
            android:layout_gravity="bottom|end"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlaySilpiCircleImage" />
    </FrameLayout>

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/imageViewProfile"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_centerVertical="true"
        android:scaleType="centerCrop"
        android:src="@drawable/padang"
        app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlaySilpiCircleImage" />

    <TextView
        android:id="@+id/textViewRoomName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignTop="@id/imageViewProfile"
        android:layout_marginStart="16dp"
        android:layout_toEndOf="@id/imageViewProfile"
        android:text="채팅방"
        android:textColor="#000000"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/textViewLastMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/textViewRoomName"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:layout_toStartOf="@id/textViewTime"
        android:layout_toEndOf="@id/imageViewProfile"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="대화를 시작해보세요"
        android:textColor="#666666"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/textViewTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:text="오후 3:24"
        android:textColor="#888888"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/textViewUnreadCount"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_alignParentEnd="true"
        android:layout_below="@id/textViewTime"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_unread_count"
        android:gravity="center"
        android:text="2"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:textStyle="bold" />

</RelativeLayout>
