<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_chat_menu_sheet"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="20dp"
        android:paddingEnd="24dp"
        android:paddingBottom="28dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/buttonCloseMenu"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@android:color/transparent"
                android:contentDescription="닫기"
                android:padding="8dp"
                android:src="@drawable/ic_chat_back" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <ImageButton
                android:id="@+id/buttonMenuMute"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@android:color/transparent"
                android:contentDescription="알림"
                android:padding="8dp"
                android:src="@android:drawable/ic_lock_silent_mode" />

            <ImageButton
                android:id="@+id/buttonMenuFavorite"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginStart="8dp"
                android:background="@android:color/transparent"
                android:contentDescription="즐겨찾기"
                android:padding="8dp"
                android:src="@android:drawable/btn_star_big_off" />

            <ImageButton
                android:id="@+id/buttonMenuSettings"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginStart="8dp"
                android:background="@android:color/transparent"
                android:contentDescription="설정"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_manage" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/layoutMenuProfileCluster"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="18dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imageMenuProfile1"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:layout_gravity="top|start"
                android:scaleType="centerCrop"
                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlaySilpiCircleImage" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imageMenuProfile2"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:layout_gravity="top|end"
                android:scaleType="centerCrop"
                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlaySilpiCircleImage" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imageMenuProfile3"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:layout_gravity="bottom|start"
                android:scaleType="centerCrop"
                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlaySilpiCircleImage" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imageMenuProfile4"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:layout_gravity="bottom|end"
                android:scaleType="centerCrop"
                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlaySilpiCircleImage" />
        </FrameLayout>

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imageMenuSingleProfile"
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="18dp"
            android:scaleType="centerCrop"
            android:visibility="gone"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlaySilpiCircleImage" />

        <TextView
            android:id="@+id/textViewMenuRoomName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center"
            android:text="채팅방"
            android:textColor="#111111"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textViewMenuParticipantTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:text="대화상대"
            android:textColor="#222222"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textViewInvitePlaceholder"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:text="+  초대하기"
            android:textColor="#007AFF"
            android:textSize="16sp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewMenuParticipants"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false" />

        <TextView
            android:id="@+id/textViewShowAllParticipants"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:gravity="center"
            android:text="전체보기"
            android:textColor="#666666"
            android:textSize="15sp"
            android:visibility="gone" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_chat_menu_divider" />

        <TextView
            android:id="@+id/textViewExitChatRoom"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:gravity="center_vertical"
            android:text="채팅방 나가기"
            android:textColor="#E85D3F"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textViewMenuCreatedInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:textColor="#777777"
            android:textSize="14sp" />
    </LinearLayout>
</ScrollView>
