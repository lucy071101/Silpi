<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:orientation="vertical">

    <View
        android:layout_width="match_parent"
        android:layout_height="62dp"
        android:background="#806BB0" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:background="#FFFFFF"
        android:paddingStart="36dp"
        android:paddingEnd="34dp">

        <TextView
            android:id="@+id/textViewTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:text="대화"
            android:textColor="#162033"
            android:textSize="34sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/editTextChatSearch"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_alignParentStart="true"
            android:layout_alignParentBottom="true"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="24dp"
            android:layout_toStartOf="@id/buttonCloseSearch"
            android:background="@android:color/transparent"
            android:hint="채팅방 검색"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:maxLength="20"
            android:singleLine="true"
            android:textColor="#162033"
            android:textColorHint="#8B93A1"
            android:textSize="24sp"
            android:visibility="gone" />

        <ImageButton
            android:id="@+id/buttonAddRoom"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@android:color/transparent"
            android:contentDescription="추가"
            android:padding="8dp"
            android:src="@android:drawable/ic_input_add"
            app:tint="#324052" />

        <TextView
            android:id="@+id/textViewAddLabel"
            android:layout_width="52dp"
            android:layout_height="wrap_content"
            android:layout_alignStart="@id/buttonAddRoom"
            android:layout_below="@id/buttonAddRoom"
            android:gravity="center"
            android:text="추가"
            android:textColor="#324052"
            android:textSize="14sp" />

        <ImageButton
            android:id="@+id/buttonSearch"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_toStartOf="@id/buttonAddRoom"
            android:layout_centerVertical="true"
            android:layout_marginEnd="10dp"
            android:background="@android:color/transparent"
            android:contentDescription="검색"
            android:padding="6dp"
            android:src="@drawable/ic_chat_search_bold" />

        <TextView
            android:id="@+id/textViewSearchLabel"
            android:layout_width="52dp"
            android:layout_height="wrap_content"
            android:layout_alignStart="@id/buttonSearch"
            android:layout_below="@id/buttonSearch"
            android:gravity="center"
            android:text="검색"
            android:textColor="#324052"
            android:textSize="14sp" />

        <ImageButton
            android:id="@+id/buttonCloseSearch"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@android:color/transparent"
            android:padding="6dp"
            android:src="@drawable/ic_chat_close_bold"
            android:visibility="gone" />

        <ImageButton
            android:id="@+id/buttonSettings"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_menu_manage"
            android:visibility="invisible"
            app:tint="#324052" />
    </RelativeLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E5E7EB" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewChatRoom"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FFFFFF"
        android:fadeScrollbars="false"
        android:scrollbars="vertical" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:gravity="center"
        android:paddingTop="10dp"
        android:paddingBottom="18dp"
        android:text="대화방을 길게 누르면 나갈 수 있어요"
        android:textColor="#9AA1AD"
        android:textSize="13sp" />

</LinearLayout>
