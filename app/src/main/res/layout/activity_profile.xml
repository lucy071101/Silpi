<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_profile_screen"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="28dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_profile_card"
            android:clipToOutline="true"
            android:orientation="vertical">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:paddingStart="18dp"
                android:paddingEnd="18dp">

                <ImageButton
                    android:id="@+id/buttonBack"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_centerVertical="true"
                    android:background="@android:color/transparent"
                    android:contentDescription="뒤로가기"
                    android:src="@android:drawable/ic_media_previous" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="프로필"
                    android:textColor="#111827"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/buttonSave"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@android:color/transparent"
                    android:contentDescription="저장"
                    android:src="@android:drawable/ic_menu_save" />
            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E5E7EB" />

            <LinearLayout
                android:id="@+id/layoutProfileLoadError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingTop="20dp"
                android:paddingEnd="24dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/textViewProfileLoadError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="프로필 정보를 불러오지 못했습니다. 잠시 후 다시 시도해주세요."
                    android:textColor="#B45309"
                    android:textSize="15sp"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/buttonRetryProfileLoad"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:text="다시 시도"
                    android:visibility="gone" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingTop="48dp"
                android:paddingBottom="44dp">

                <ImageView
                    android:id="@+id/imageProfile"
                    android:layout_width="132dp"
                    android:layout_height="132dp"
                    android:background="@drawable/bg_profile_image_ring"
                    android:clipToOutline="true"
                    android:contentDescription="프로필 사진 수정"
                    android:padding="3dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/padang" />

                <EditText
                    android:id="@+id/editTextName"
                    android:layout_width="220dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:background="@drawable/bg_edit_text_clear"
                    android:gravity="center"
                    android:hint="이름"
                    android:inputType="textPersonName"
                    android:maxLines="1"
                    android:textColor="#111827"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/editTextCity"
                    android:layout_width="220dp"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_edit_text_clear"
                    android:gravity="center"
                    android:hint="지역"
                    android:inputType="text"
                    android:maxLines="1"
                    android:textColor="#777777"
                    android:textSize="18sp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="10dp"
                android:background="@drawable/bg_section_divider" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingTop="28dp"
                android:paddingEnd="24dp"
                android:paddingBottom="28dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="자기소개"
                    android:textColor="#777777"
                    android:textSize="20sp" />

                <EditText
                    android:id="@+id/editTextBio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/bg_edit_text_clear"
                    android:gravity="top"
                    android:hint="자기소개를 입력하세요"
                    android:inputType="textMultiLine"
                    android:minLines="4"
                    android:textColor="#2F3742"
                    android:textSize="18sp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="10dp"
                android:background="@drawable/bg_section_divider" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingTop="28dp"
                android:paddingEnd="24dp"
                android:paddingBottom="36dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="취미 및 관심사"
                    android:textColor="#777777"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/textViewInterests"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/bg_interest_chip"
                    android:paddingStart="18dp"
                    android:paddingTop="14dp"
                    android:paddingEnd="18dp"
                    android:paddingBottom="14dp"
                    android:textColor="#11864F"
                    android:textSize="17sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
