<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="start"
    android:padding="4dp">

    <!-- 보낸 사람 이름 -->
    <TextView
        android:id="@+id/textViewSenderNameLeft"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp"
        android:layout_marginBottom="2dp"
        android:text="민수"
        android:textSize="12sp"
        android:textColor="#888888" />

    <!-- 메시지 -->
    <TextView
        android:id="@+id/textViewMessageLeft"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_chat_left"
        android:maxWidth="250dp"
        android:padding="12dp"
        android:text="상대 메시지"
        android:textSize="16sp" />

    <ImageView
        android:id="@+id/imageViewMessageLeft"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:background="@drawable/bg_chat_left"
        android:contentDescription="이미지 메시지"
        android:padding="4dp"
        android:scaleType="centerCrop"
        android:visibility="gone" />

    <!-- 시간 -->
    <TextView
        android:id="@+id/textViewTimeLeft"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="오후 2:15"
        android:textColor="#888888"
        android:textSize="12sp" />

</LinearLayout>
