<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#F5F5F5"
        android:padding="12dp"
        android:gravity="center_vertical">
        <EditText
            android:id="@+id/et_search_community"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="관심있는 커뮤니티 검색"
            android:background="@null"
            android:padding="12dp"
            android:textSize="18sp" />
        <ImageView
            android:id="@+id/btn_search"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_menu_search"
            android:layout_marginEnd="12dp"/>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⭐ 즐겨찾는 카테고리"
        android:textStyle="bold"
        android:textSize="24sp"
        android:textColor="#000000"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="16dp"/>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button
                android:id="@+id/btn_category_baduk"
                android:layout_width="wrap_content"
                android:layout_height="60dp"
                android:text="#바둑"
                android:textSize="20sp"
                android:backgroundTint="#EEEEEE"
                android:textColor="#333333"
                android:layout_marginEnd="12dp"/>
            <Button
                android:id="@+id/btn_category_hike"
                android:layout_width="wrap_content"
                android:layout_height="60dp"
                android:text="#등산"
                android:textSize="20sp"
                android:backgroundTint="#EEEEEE"
                android:textColor="#333333"
                android:layout_marginEnd="12dp"/>
            <Button
                android:id="@+id/btn_category_walk"
                android:layout_width="wrap_content"
                android:layout_height="60dp"
                android:text="#산책"
                android:textSize="20sp"
                android:backgroundTint="#EEEEEE"
                android:textColor="#333333"
                android:layout_marginEnd="12dp"/>
            <Button
                android:id="@+id/btn_category_fish"
                android:layout_width="wrap_content"
                android:layout_height="60dp"
                android:text="#낚시"
                android:textSize="20sp"
                android:backgroundTint="#EEEEEE"
                android:textColor="#333333"
                android:layout_marginEnd="12dp"/>
        </LinearLayout>
    </HorizontalScrollView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🔥 실시간 인기 커뮤니티"
        android:textStyle="bold"
        android:textSize="24sp"
        android:textColor="#000000"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="16dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_popular_communities"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="20dp"
        tools:listitem="@layout/item_community" />

</LinearLayout>