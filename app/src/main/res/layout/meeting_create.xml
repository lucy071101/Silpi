<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="모임 생성"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <Spinner
            android:id="@+id/spinnerCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <EditText
            android:id="@+id/edtPeople"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="참여 인원"
            android:inputType="number" />

        <EditText
            android:id="@+id/edtPlace"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="예: 삼육대학교, 공릉역, 불암산" />

        <Button
            android:id="@+id/btnCheckPlace"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="장소 확인" />

        <TextView
            android:id="@+id/txtPlaceCheck"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="장소 확인 전입니다." />

        <WebView
            android:id="@+id/webPlaceSearch"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:alpha="0.01" />

        <EditText
            android:id="@+id/edtDistance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="참여 가능 거리(km)"
            android:inputType="number" />

        <EditText
            android:id="@+id/edtDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="예: 2026-04-05" />

        <EditText
            android:id="@+id/edtTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="예: 14:00" />

        <CheckBox
            android:id="@+id/chkGuardian"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="보호자 동반" />

        <EditText
            android:id="@+id/edtDesc"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:hint="모임 설명"
            android:gravity="top"
            android:inputType="textMultiLine" />

        <Button
            android:id="@+id/btnCreate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="모임 생성" />

        <TextView
            android:id="@+id/txtResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="여기에 생성 결과가 표시됩니다." />

    </LinearLayout>
</ScrollView>