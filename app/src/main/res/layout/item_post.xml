<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#EEEEEE"
    android:layout_marginBottom="12dp"
    android:layout_marginHorizontal="16dp">

    <TextView
        android:id="@+id/tv_item_post_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="오늘 바둑 두실 분 계신가요?"
        android:textSize="28sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-black"
        android:textColor="#000000"
        android:maxLines="1"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/tv_item_post_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="오후 3시쯤 마을회관에서 바둑 한 판 하실 분 구합니다..."
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:layout_marginTop="8dp"
        android:maxLines="2"
        android:ellipsize="end" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_item_post_author"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="익명"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#666666" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" · "
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#666666" />

        <TextView
            android:id="@+id/tv_item_post_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10분 전"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#666666"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/tv_item_post_recommend"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👍 3"
            android:textSize="20sp"
            android:textColor="#F44336"
            android:layout_marginEnd="16dp" />

        <TextView
            android:id="@+id/tv_item_post_comment"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💬 5"
            android:textSize="20sp"
            android:textColor="#2196F3" />
    </LinearLayout>
</LinearLayout>